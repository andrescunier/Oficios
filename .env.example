# =========================================
# CONFIGURACIÓN PRINCIPAL
# =========================================
# Copia este archivo a .env y ajusta los valores

# =========================================
# API CONFIGURATION
# =========================================
# URL base de la API SIGP
VITE_API_BASE_URL=https://api.cumar.com.ar

# ID de la cuenta (multi-tenant)
VITE_ACCOUNT_ID=37b694f4-f2c9-4500-8e47-52b8ad8daaea

# Headers adicionales para la API
VITE_API_EXTRA_HEADERS={}

# =========================================
# CDN CONFIGURATION (Opcional - Requiere repositorio público)
# =========================================
# URLs del CDN para servir assets estáticos usando jsDelivr
# Si no están configuradas, se usarán las rutas locales desde /public
# NOTA: Para usar jsDelivr, el repositorio GitHub debe ser PÚBLICO
#
# Para configurar automáticamente:
#   1. Asegúrate de que tu repositorio sea público en GitHub
#   2. Haz push de las imágenes a GitHub
#   3. Ejecuta: ./setup-cdn.sh
#   4. Copia las URLs generadas a este archivo
#
# VITE_CDN_HERO_SLIDE_1=https://cdn.jsdelivr.net/gh/usuario/repo@main/public/images/heroes/slide-1.jpg
# VITE_CDN_HERO_SLIDE_2=https://cdn.jsdelivr.net/gh/usuario/repo@main/public/images/heroes/slide-2.jpg
# VITE_CDN_HERO_SLIDE_3=https://cdn.jsdelivr.net/gh/usuario/repo@main/public/images/heroes/slide-3.jpg
# VITE_CDN_LOGO=https://cdn.jsdelivr.net/gh/usuario/repo@main/public/diap-logo.png

# =========================================
# BRANDING & COMPANY INFO
# =========================================
# Nombre de la aplicación
VITE_APP_NAME=DIAP

# Nombre completo de la empresa
VITE_COMPANY_NAME=DIAP

# Slogan o descripción corta
VITE_APP_SLOGAN=Tecnología profesional para empresas

# URL del sitio web
VITE_APP_URL=https://localhost:5173

# Descripción de la aplicación
VITE_APP_DESCRIPTION=DIAP - Distribuidora de productos tecnológicos de primera calidad. Soluciones profesionales para tu empresa.

# Email de contacto
VITE_CONTACT_EMAIL=info@diap.com

# Teléfono de contacto
VITE_CONTACT_PHONE=+1 (786) 513-3960

# Dirección física
VITE_CONTACT_ADDRESS=Av. Corrientes 1234, CABA, Argentina

# =========================================
# LOGOS & IMAGES
# =========================================
# Logo principal de la aplicación
VITE_LOGO_PATH=/diap-logo.png

# Favicon del sitio
VITE_FAVICON_PATH=/favicon.ico

# Logo para el header (puede ser diferente al principal)
VITE_HEADER_LOGO_PATH=/diap-logo.png

# Logo para el footer (puede ser diferente)
VITE_FOOTER_LOGO_PATH=/diap-logo.png

# =========================================
# HERO SLIDER IMAGES
# =========================================
# Imágenes del carrusel principal (mínimo 3)
VITE_HERO_SLIDE_1=/images/heroes/slide-1.jpg
VITE_HERO_SLIDE_2=/images/heroes/slide-2.jpg
VITE_HERO_SLIDE_3=/images/heroes/slide-3.jpg
VITE_HERO_SLIDE_4=/images/heroes/slide-4.jpg
VITE_HERO_SLIDE_5=/images/heroes/slide-5.jpg

# Textos del slider (opcionales)
VITE_HERO_SLIDE_1_TITLE=Tecnología de Vanguardia
VITE_HERO_SLIDE_1_SUBTITLE=Descubre los mejores productos tecnológicos
VITE_HERO_SLIDE_1_CTA=Ver Productos

VITE_HERO_SLIDE_2_TITLE=Gaming Premium
VITE_HERO_SLIDE_2_SUBTITLE=Lleva tu experiencia gaming al siguiente nivel
VITE_HERO_SLIDE_2_CTA=Explorar Gaming

VITE_HERO_SLIDE_3_TITLE=Componentes Pro
VITE_HERO_SLIDE_3_SUBTITLE=Hardware profesional para desarrolladores
VITE_HERO_SLIDE_3_CTA=Ver Componentes

# =========================================
# CATEGORY IMAGES
# =========================================
# Imágenes de categorías de productos
VITE_CATEGORY_COMPONENTES_IMG=/images/categories/componentes.jpg
VITE_CATEGORY_GAMING_IMG=/images/categories/gaming.jpg
VITE_CATEGORY_DDR4_IMG=/images/categories/ddr4.jpg
VITE_CATEGORY_DDR5_IMG=/images/categories/ddr5.jpg
VITE_CATEGORY_SSD_M2_IMG=/images/categories/ssd-m2.jpg
VITE_CATEGORY_SSD_SATA_IMG=/images/categories/ssd-sata.jpg

# =========================================
# BANNER & PROMOTIONAL IMAGES
# =========================================
# Banner principal de ofertas
VITE_BANNER_MAIN=/images/banners/main-banner.jpg
VITE_BANNER_SECONDARY=/images/banners/secondary-banner.jpg

# Banners de temporada
VITE_BANNER_SEASONAL=/images/banners/seasonal-banner.jpg
VITE_BANNER_SALE=/images/banners/sale-banner.jpg

# =========================================
# BACKGROUND IMAGES
# =========================================
# Imagen de fondo para secciones especiales
VITE_BG_HERO=/images/backgrounds/hero-bg.jpg
VITE_BG_FEATURES=/images/backgrounds/features-bg.jpg
VITE_BG_TESTIMONIALS=/images/backgrounds/testimonials-bg.jpg

# =========================================
# PLACEHOLDER IMAGES
# =========================================
# Imagen por defecto para productos sin imagen
VITE_PLACEHOLDER_PRODUCT=/images/placeholders/product-placeholder.jpg
VITE_PLACEHOLDER_CATEGORY=/images/placeholders/category-placeholder.jpg
VITE_PLACEHOLDER_USER=/images/placeholders/user-placeholder.jpg

# =========================================
# SOCIAL MEDIA & LINKS
# =========================================
# Facebook
VITE_FACEBOOK_URL=https://facebook.com/iamerican

# Instagram
VITE_INSTAGRAM_URL=https://instagram.com/iamerican

# Twitter/X
VITE_TWITTER_URL=https://twitter.com/iamerican

# LinkedIn
VITE_LINKEDIN_URL=https://linkedin.com/company/iamerican

# =========================================
# APP CONFIGURATION
# =========================================
# Entorno de la aplicación
VITE_APP_ENV=development

# Versión de la aplicación
VITE_APP_VERSION=1.0.0

# Habilitar logs de API
VITE_ENABLE_API_LOGGING=true

# Habilitar modo debug
VITE_DEBUG_MODE=false

# =========================================
# FEATURE FLAGS
# =========================================
# Habilitar notificaciones
VITE_ENABLE_NOTIFICATIONS=true

# Habilitar analytics
VITE_ENABLE_ANALYTICS=false

# Habilitar pagos reales
VITE_ENABLE_REAL_PAYMENTS=true

# Habilitar modo demo
VITE_DEMO_MODE=true

# Ocultar precios para usuarios no autenticados (DIAP B2B Feature)
VITE_HIDE_PRICES_FOR_GUESTS=true

# Mensaje para usuarios no autenticados
VITE_LOGIN_TO_VIEW_PRICES_MESSAGE=Inicia sesión para ver precios

# Texto del botón de login para ver precios
VITE_LOGIN_FOR_PRICES_CTA=Iniciar Sesión

# Requiere autenticación para agregar al carrito (DIAP B2B Feature)
VITE_REQUIRE_AUTH_FOR_CART=true

# =========================================
# COLORS & THEMING
# =========================================
# Color primario (CSS custom property)
VITE_PRIMARY_COLOR=#2563eb

# Color secundario
VITE_SECONDARY_COLOR=#7c3aed

# Color de acento
VITE_ACCENT_COLOR=#059669

# ============================================
# SHIPPING & BENEFITS FEATURES
# ============================================
VITE_FEATURE_FREE_SHIPPING_TITLE=Envío Gratis
VITE_FEATURE_FREE_SHIPPING_DESC=En compras superiores a $50.000
VITE_FEATURE_FREE_RETURNS_TITLE=Devolución Gratis
VITE_FEATURE_FREE_RETURNS_DESC=Hasta 30 días para devolver
VITE_FEATURE_SECURE_PURCHASE_TITLE=Compra Segura
VITE_FEATURE_SECURE_PURCHASE_DESC=Protegemos tus datos
VITE_FEATURE_MULTIPLE_PAYMENTS_TITLE=Múltiples Pagos
VITE_FEATURE_MULTIPLE_PAYMENTS_DESC=Tarjetas, transferencia y más