{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "shell",
			"label": "dev-server",
			"command": "pnpm",
			"args": [
				"dev"
			],
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": true,
				"clear": false
			},
			"isBackground": true,
			"problemMatcher": {
				"owner": "vite",
				"pattern": {
					"regexp": "^(.*)$",
					"file": 1
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "^\\s*VITE",
					"endsPattern": "Local:\\s+http://localhost"
				}
			}
		},
		{
			"label": "preview-app",
			"type": "shell",
			"command": "pnpm",
			"args": [
				"dev"
			],
			"isBackground": true,
			"group": "build"
		}
	]
}